# ══════════════════════════════════════════════════════════════════════════════
# example.env — Plantilla de configuración
# Herramienta de migración PHP → NestJS
#
# Instrucciones:
#   1. Copia este archivo como .env en la raíz del proyecto
#   2. Completa las rutas según tu máquina local
#   3. Ejecuta: bash setup.sh  (te guía paso a paso)
#
# IMPORTANTE: el archivo .env está en .gitignore y nunca debe subirse al repo.
# ══════════════════════════════════════════════════════════════════════════════

# ── Repositorios ──────────────────────────────────────────────────────────────

# Ruta local al repositorio PHP/CodeIgniter que estás migrando
# Ejemplo Windows : D:/HomeLand/PHP Migration/api-backend
# Ejemplo Mac/Linux: /Users/tuusuario/proyectos/api-backend
PHP2NODE_REPO_ROOT=

# Ruta local al repositorio NestJS destino (akisi_backend_nestjs)
# Se usa para detectar puertos disponibles y generar instrucciones con rutas correctas
AKISI_REPO_ROOT=

# ── Inventarios Excel ─────────────────────────────────────────────────────────

# Inventario de endpoints versión 1
PHP2NODE_INVENTORY_V1_XLSX=

# Inventario de endpoints versión 2
PHP2NODE_INVENTORY_V2_XLSX=

# Nombre de la hoja dentro del Excel (default: EndPoints)
PHP2NODE_SHEET=EndPoints

# ── Salida ────────────────────────────────────────────────────────────────────

# Carpeta donde se genera el output de cada migración
PHP2NODE_OUT=./out

# ── Scope de búsqueda en el repo PHP ─────────────────────────────────────────

# Define en qué parte del repo PHP buscar los controllers
# Valores posibles: api | portal | auto
# Se recomienda "auto" para dejar que la herramienta lo detecte
PHP2NODE_APP=auto
